{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp.ReverseProxy": "Information"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "event-route": {
        "ClusterId": "event-cluster",
        "Match": { "Path": "/api/event/{**catch-all}" }
      },
      "eventtype-route": {
        "ClusterId": "event-cluster",
        "Match": { "Path": "/api/eventtype/{**catch-all}" }
      },
      "sessions-route": {
        "ClusterId": "event-cluster",
        "Match": { "Path": "/api/sessions/{**catch-all}" }
      },
      "sessionbookings-route": {
        "ClusterId": "event-cluster",
        "Match": { "Path": "/api/sessionbookings/{**catch-all}" }
      },
      "tickettypes-route": {
        "ClusterId": "event-cluster",
        "Match": { "Path": "/api/tickettypes/{**catch-all}" }
      },
      "tracks-route": {
        "ClusterId": "event-cluster",
        "Match": { "Path": "/api/tracks/{**catch-all}" }
      },
      "talent-route": {
        "ClusterId": "event-cluster",
        "Match": { "Path": "/api/talent/{**catch-all}" }
      },
      "checkin-route": {
        "ClusterId": "event-cluster",
        "Match": { "Path": "/api/checkin/{**catch-all}" }
      },
      "lineup-route": {
        "ClusterId": "event-cluster",
        "Match": { "Path": "/api/lineup/{**catch-all}" }
      },
      "media-route": {
        "ClusterId": "event-cluster",
        "Match": { "Path": "/api/media/{**catch-all}" }
      },
      "auth-route": {
        "ClusterId": "identity-cluster",
        "Match": { "Path": "/api/auth/{**catch-all}" }
      },
      "otp-route": {
        "ClusterId": "identity-cluster",
        "Match": { "Path": "/api/otp/{**catch-all}" }
      },
      "user-route": {
        "ClusterId": "identity-cluster",
        "Match": { "Path": "/api/user/{**catch-all}" }
      },
      "orders-route": {
        "ClusterId": "booking-cluster",
        "Match": { "Path": "/api/orders/{**catch-all}" }
      },
      "orderdetails-route": {
        "ClusterId": "booking-cluster",
        "Match": { "Path": "/api/orderdetails/{**catch-all}" }
      },
      "payments-route": {
        "ClusterId": "booking-cluster",
        "Match": { "Path": "/api/payments/{**catch-all}" }
      },
      "paymentmethods-route": {
        "ClusterId": "booking-cluster",
        "Match": { "Path": "/api/paymentmethods/{**catch-all}" }
      },
      "payoutrequests-route": {
        "ClusterId": "booking-cluster",
        "Match": { "Path": "/api/payoutrequests/{**catch-all}" }
      },
      "tickets-route": {
        "ClusterId": "booking-cluster",
        "Match": { "Path": "/api/tickets/{**catch-all}" }
      },
      "ai-route": {
        "ClusterId": "ai-cluster",
        "Match": { "Path": "/api/ai/{**catch-all}" }
      },
      "emailcampaign-route": {
        "ClusterId": "notification-cluster",
        "Match": { "Path": "/api/emailcampaign/{**catch-all}" }
      },
      "emaillog-route": {
        "ClusterId": "notification-cluster",
        "Match": { "Path": "/api/emaillog/{**catch-all}" }
      },
      "email-route": {
        "ClusterId": "notification-cluster",
        "Match": { "Path": "/api/email/{**catch-all}" }
      },
      "notification-route": {
        "ClusterId": "notification-cluster",
        "Match": { "Path": "/api/notification/{**catch-all}" }
      },
      "usernotification-route": {
        "ClusterId": "notification-cluster",
        "Match": { "Path": "/api/usernotification/{**catch-all}" }
      }
    },
    "Clusters": {
      "event-cluster": {
        "Destinations": {
          "event-service": {
            "Address": "http://event-service:8080/"
          }
        }
      },
      "identity-cluster": {
        "Destinations": {
          "identity-service": {
            "Address": "http://identity-service:8080/"
          }
        }
      },
      "booking-cluster": {
        "Destinations": {
          "booking-service": {
            "Address": "http://booking-service:8080/"
          }
        }
      },
      "ai-cluster": {
        "Destinations": {
          "ai-service": {
            "Address": "http://ai-service:8080/"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "notification-service": {
            "Address": "http://notification-service:8080/"
          }
        }
      }
    }
  }
}
